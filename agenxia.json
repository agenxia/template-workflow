{
  "name": "{{AGENT_NAME}}",
  "version": "1.0.0",
  "description": "{{AGENT_DESCRIPTION}}",
  "type": "agent",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}, a workflow orchestration agent.",
    "model": "llama-3.3-70b",
    "temperature": 0.3,
    "max_tokens": 4096
  },
  "env_vars": ["LLM_API_URL", "LLM_API_KEY"],
  "ports": {
    "inputs": [
      { "id": "input", "label": "Input", "type": "json" },
      { "id": "step_override", "label": "Step Override", "type": "text" }
    ],
    "outputs": [
      { "id": "output", "label": "Output", "type": "json" },
      { "id": "steps", "label": "Steps", "type": "json" }
    ]
  },
  "methods": [
    {
      "name": "process",
      "description": "Execute workflow with input data",
      "params": {
        "input": { "type": "object", "from_port": "input" },
        "step_override": { "type": "string", "from_port": "step_override" }
      },
      "returns": {
        "output": { "type": "object", "to_port": "output" },
        "steps": { "type": "array", "to_port": "steps" }
      }
    }
  ],
  "api": {
    "execute": { "type": "post", "description": "Execute workflow" },
    "status": { "type": "get", "description": "Agent status" }
  }
}